# Supabase Configuration
# Get these from your Supabase project settings at https://supabase.com
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Trigger.dev Configuration
# Get this from your Trigger.dev project settings at https://trigger.dev
TRIGGER_SECRET_KEY=your_trigger_secret_key

# Run view logs: Trigger tasks send logs to the app so the dashboard can show a run view.
# Set in Trigger.dev env (and optionally here for local dev). LOG_SECRET can be any shared secret.
APP_URL=http://localhost:3000
LOG_SECRET=your_shared_secret_for_log_endpoint

# Browser Use Cloud (optional)
# When set, scraping uses Browser Use Cloud browsers via CDP for better anti-detection.
# Get your API key at https://cloud.browser-use.com
BROWSER_USE_API_KEY=

# Oxylabs Web Unblocker (optional) – bypass Cloudflare when using local browser
# When set, all browser traffic uses this proxy. Only applies when BROWSER_USE_API_KEY is not set.
# Get credentials at https://dashboard.oxylabs.io (Web Unblocker product).
# Proxy server defaults to https://unblock.oxylabs.io:60000 if not set.
OXYLABS_PROXY_USERNAME=
OXYLABS_PROXY_PASSWORD=
# OXYLABS_PROXY_SERVER=https://unblock.oxylabs.io:60000

# Auth (optional) – defaults: admin@gmail.com / admin@123 if not set
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin@123

# Milled Pro (optional) – when set, scraper logs in for Pro date range and full archive
MILLED_PRO_EMAIL=
MILLED_PRO_PASSWORD=
